{
  "name": "agent-peers-mcp",
  "displayName": "Agent Peers",
  "version": "0.1.0",
  "description": "Cross-agent context sharing MCP server & VSCode extension — Claude Code, Codex, GitHub Copilot Chat, and more",
  "publisher": "agent-peers",
  "license": "MIT",

  "main": "./out/extension/index.js",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-peers",
          "title": "Agent Peers",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-peers": [
        {
          "id": "agentPeers.control",
          "name": "Control"
        },
        {
          "id": "agentPeers.peerList",
          "name": "Peers"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentPeers.peerList",
        "contents": "Broker is not running.\n[Start Broker](command:agentPeers.startBroker)",
        "when": "!agentPeers.brokerConnected"
      },
      {
        "view": "agentPeers.peerList",
        "contents": "No peers connected.",
        "when": "agentPeers.brokerConnected"
      }
    ],
    "commands": [
{
        "command": "agentPeers.sendMessage",
        "title": "Send Message to Peer",
        "icon": "$(comment)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.shareContext",
        "title": "Share Current Context",
        "icon": "$(broadcast)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.startBroker",
        "title": "Start Broker Daemon",
        "icon": "$(play)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.stopBroker",
        "title": "Stop Broker",
        "icon": "$(debug-stop)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.showDashboard",
        "title": "Show Dashboard",
        "icon": "$(dashboard)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.disconnectPeer",
        "title": "Suspend Peer",
        "icon": "$(debug-disconnect)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.connectPeer",
        "title": "Resume Peer",
        "icon": "$(plug)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.addMcpServer",
        "title": "Config Claude Code to MCP",
        "icon": "$(plug)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.addMcpServerCodex",
        "title": "Config Codex to MCP",
        "icon": "$(plug)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.toggleAutoStart",
        "title": "Toggle Auto-Start Broker",
        "icon": "$(settings-gear)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.configConflictHook",
        "title": "Config Conflict Detection Hook",
        "icon": "$(shield)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.toggleAutoDelivery",
        "title": "Toggle Auto Delivery Message",
        "icon": "$(debug-pause)",
        "category": "Agent Peers"
      },
      {
        "command": "agentPeers.markReportsRead",
        "title": "Mark Reports as Read",
        "icon": "$(check-all)",
        "category": "Agent Peers"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "agentPeers.startBroker",
          "when": "explorerResourceIsFolder",
          "group": "agentPeers@1"
        }
      ],
      "commandPalette": [
        {
          "command": "agentPeers.startBroker"
        }
      ],
      "view/item/context": [],
      "view/title": [
      ]
    },
    "configuration": {
      "title": "Agent Peers",
      "properties": {
        "agentPeers.brokerPort": {
          "type": "number",
          "default": 7899,
          "description": "Port for the broker daemon"
        },
        "agentPeers.autoStartBroker": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the broker daemon when the extension activates"
        },
        "agentPeers.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "description": "Polling interval for messages (milliseconds)"
        },
        "agentPeers.autoDeliveryMessage": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, incoming peer messages (text, task-handoff, context-request, etc.) are auto-delivered to the terminal. When disabled, messages are shown as notifications for manual approval before delivery."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:broker && npm run build:server && npm run build:extension && npm run build:hooks",
    "build:broker": "esbuild src/broker/index.ts --bundle --outfile=out/broker/index.js --platform=node --format=cjs",
    "build:server": "esbuild src/server/index.ts --bundle --outfile=out/server/index.js --platform=node --format=cjs",
    "build:extension": "esbuild src/extension/index.ts --bundle --outfile=out/extension/index.js --platform=node --format=cjs --external:vscode",
    "build:hooks": "esbuild src/hooks/check-conflicts.ts --bundle --outfile=out/hooks/check-conflicts.js --platform=node --format=cjs",
    "dev:broker": "npm run build:broker && node out/broker/index.js",
    "dev:server": "npm run build:server && node out/server/index.js",
    "watch": "esbuild src/extension/index.ts --bundle --outfile=out/extension/index.js --platform=node --format=cjs --external:vscode --watch",
    "package": "vsce package",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.0"
  }
}
